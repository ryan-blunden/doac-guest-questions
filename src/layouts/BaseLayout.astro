---
type NavItem = {
  href: string;
  label: string;
};

interface Props {
  title: string;
  description?: string;
  activePath?: string;
}

const { title, description, activePath = "/" } = Astro.props;

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
  const cleanPath = path.replace(/^\/+/, "");

  if (!cleanPath) {
    return `${base}/`;
  }

  return `${base}/${cleanPath}`;
};

const navItems: NavItem[] = [
  { href: "/", label: "Random" },
  { href: "/all", label: "All" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content={description ??
        "The questions DOAC guests left behind for the next guest."}
    />
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700;800&family=Caveat:wght@500;700&display=swap");

      :root {
        --paper: #f6f3ec;
        --paper-strong: #fffdf9;
        --ink: #141414;
        --muted: #5b5955;
        --line: rgba(20, 20, 20, 0.14);
        --line-strong: rgba(20, 20, 20, 0.32);
        --gold: #ae8d43;
        --shadow: 0 20px 50px rgba(15, 15, 15, 0.08);
        --shadow-soft: 0 10px 30px rgba(15, 15, 15, 0.05);
        --radius: 28px;
        --card-radius: 22px;
        --card-aspect: 0.678;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        background:
          radial-gradient(
            circle at top left,
            rgba(174, 141, 67, 0.12),
            transparent 32%
          ),
          linear-gradient(180deg, #fbfaf7 0%, var(--paper) 100%);
        color: var(--ink);
        font-family: "Manrope", sans-serif;
      }

      body::before {
        content: "";
        inset: 0;
        pointer-events: none;
        position: fixed;
        background-image:
          linear-gradient(rgba(20, 20, 20, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(20, 20, 20, 0.02) 1px, transparent 1px);
        background-size: 24px 24px;
        opacity: 0.18;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site-shell {
        margin: 0 auto;
        max-width: 1180px;
        padding: 24px 18px 80px;
        position: relative;
      }

      .site-header {
        align-items: center;
        backdrop-filter: blur(18px);
        background: rgba(255, 253, 249, 0.72);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow-soft);
        display: flex;
        gap: 16px;
        justify-content: space-between;
        margin-bottom: 36px;
        padding: 20px 24px;
        position: sticky;
        top: 18px;
        z-index: 10;
      }

      .brand-lockup {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .brand-kicker,
      .eyebrow,
      .small-label {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .brand-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(1.5rem, 2vw, 2rem);
        line-height: 0.95;
        margin: 0;
      }

      .nav-list {
        display: flex;
        gap: 10px;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .nav-link {
        border: 1px solid transparent;
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        padding: 10px 14px;
        text-transform: uppercase;
        transition: 180ms ease;
      }

      .nav-link:hover,
      .nav-link[aria-current="page"] {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--paper-strong);
      }

      .hero-grid {
        display: grid;
        gap: 24px;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
        margin-bottom: 36px;
      }

      .hero-panel,
      .side-panel,
      .section-panel {
        background: rgba(255, 253, 249, 0.82);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow-soft);
      }

      .hero-panel {
        overflow: hidden;
        padding: clamp(24px, 5vw, 44px);
        position: relative;
      }

      .hero-panel::after {
        background: linear-gradient(
          135deg,
          transparent 0%,
          rgba(174, 141, 67, 0.14) 100%
        );
        content: "";
        inset: 0;
        pointer-events: none;
        position: absolute;
      }

      .hero-panel > *,
      .side-panel > *,
      .section-panel > * {
        position: relative;
        z-index: 1;
      }

      .hero-title,
      .section-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(3rem, 7vw, 5.8rem);
        letter-spacing: -0.04em;
        line-height: 0.9;
        margin: 10px 0 16px;
      }

      .hero-copy,
      .section-copy {
        color: var(--muted);
        font-size: 1.03rem;
        line-height: 1.75;
        margin: 0;
        max-width: 58ch;
      }

      .side-panel {
        background: #141414;
        color: var(--paper);
        display: grid;
        gap: 18px;
        padding: 24px;
      }

      .side-panel .small-label,
      .side-panel .eyebrow {
        color: rgba(246, 243, 236, 0.7);
      }

      .side-note {
        color: rgba(246, 243, 236, 0.78);
        line-height: 1.7;
        margin: 0;
      }

      .meta-grid {
        display: grid;
        gap: 12px;
      }

      .meta-stat {
        border-top: 1px solid rgba(246, 243, 236, 0.14);
        display: grid;
        gap: 4px;
        padding-top: 12px;
      }

      .meta-value {
        font-size: 1.3rem;
        font-weight: 800;
      }

      .button-row,
      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button,
      .pill {
        align-items: center;
        border-radius: 999px;
        cursor: pointer;
        display: inline-flex;
        font-size: 0.82rem;
        font-weight: 800;
        gap: 8px;
        letter-spacing: 0.1em;
        padding: 12px 18px;
        text-transform: uppercase;
      }

      .button.primary {
        background: var(--ink);
        color: var(--paper-strong);
      }

      .button.secondary,
      .pill {
        background: rgba(255, 253, 249, 0.9);
        border: 1px solid var(--line-strong);
        color: var(--ink);
      }

      .pill.is-active {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--paper-strong);
      }

      .section-panel {
        padding: clamp(22px, 4vw, 34px);
      }

      .page-surface {
        display: grid;
        gap: 20px;
      }

      .page-filters {
        overflow: hidden;
      }

      .page-filter-bar {
        align-items: center;
        display: flex;
        gap: 12px;
        justify-content: space-between;
      }

      .page-filter-row {
        flex: 1;
        flex-wrap: nowrap;
        justify-content: flex-start;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
      }

      .page-filter-row::-webkit-scrollbar {
        display: none;
      }

      .question-card {
        aspect-ratio: var(--card-aspect);
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.98) 0%,
          rgba(248, 245, 239, 0.98) 100%
        );
        border: 1.5px solid rgba(20, 20, 20, 0.18);
        border-radius: var(--card-radius);
        box-shadow:
          0 26px 60px rgba(17, 17, 17, 0.12),
          inset 0 1px 0 rgba(255, 255, 255, 0.75);
        display: grid;
        gap: 18px;
        grid-template-rows: auto 1fr;
        overflow: hidden;
        padding: 22px 22px 20px;
        position: relative;
      }

      .question-card::before {
        background:
          radial-gradient(
            circle at top right,
            rgba(20, 20, 20, 0.05),
            transparent 36%
          ),
          linear-gradient(180deg, transparent, rgba(20, 20, 20, 0.02));
        content: "";
        inset: 0;
        pointer-events: none;
        position: absolute;
      }

      .question-card--compact {
        aspect-ratio: var(--card-aspect);
        min-height: unset;
      }

      .question-card__header {
        align-items: center;
        display: flex;
        gap: 14px;
        justify-content: flex-end;
      }

      .question-card__category {
        border: 1px solid rgba(20, 20, 20, 0.18);
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        padding: 10px 12px;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .question-card__body {
        align-items: center;
        display: flex;
        justify-content: center;
        padding: 10px 4px 18px;
      }

      .question-card__question {
        font-family: "Caveat", cursive;
        font-size: 3.2rem;
        line-height: 0.95;
        margin: 0;
        text-align: center;
        text-wrap: balance;
      }

      .cards-grid,
      .category-grid {
        display: grid;
        gap: 22px;
      }

      .cards-grid {
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      }

      .category-grid {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .category-tile {
        background: rgba(255, 253, 249, 0.88);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow-soft);
        display: grid;
        gap: 14px;
        min-height: 220px;
        padding: 22px;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease;
      }

      .category-tile:hover {
        box-shadow: var(--shadow);
        transform: translateY(-4px);
      }

      .category-name {
        font-family: "Cormorant Garamond", serif;
        font-size: 2rem;
        margin: 0;
      }

      .category-note {
        color: var(--muted);
        line-height: 1.7;
        margin: 0;
      }

      .empty-state {
        border: 1px dashed var(--line-strong);
        border-radius: var(--radius);
        color: var(--muted);
        padding: 32px;
        text-align: center;
      }

      @media (max-width: 900px) {
        .site-header,
        .hero-grid {
          border-radius: 26px;
          grid-template-columns: 1fr;
        }

        .site-header {
          align-items: flex-start;
          border-radius: 30px;
          flex-direction: column;
        }

        .nav-list {
          width: 100%;
        }

        .nav-link {
          flex: 1;
          justify-content: center;
          text-align: center;
        }
      }

      @media (max-width: 640px) {
        .site-shell {
          padding-inline: 14px;
        }

        .hero-title,
        .section-title {
          font-size: 2.9rem;
        }

        .nav-list {
          flex-wrap: wrap;
        }

        .site-header {
          padding: 18px;
        }

        .nav-link {
          font-size: 0.74rem;
          letter-spacing: 0.08em;
          padding: 9px 12px;
        }

        .page-filter-row {
          gap: 8px;
        }

        .page-filters .pill {
          font-size: 0.74rem;
          letter-spacing: 0.08em;
          padding: 9px 12px;
        }

        .page-filter-bar {
          align-items: stretch;
          flex-direction: column;
        }

        .question-card {
          padding: 18px;
        }

        .question-card__header {
          justify-content: flex-start;
        }

        .question-card__question {
          font-size: 3.2rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="brand-lockup">
          <span class="brand-kicker">The Diary Of A CEO</span>
          <h1 class="brand-title">Closing Questions</h1>
        </div>
        <nav aria-label="Primary">
          <ul class="nav-list">
            {
              navItems.map((item) => (
                <li>
                  <a
                    class="nav-link"
                    href={withBase(item.href)}
                    aria-current={activePath === item.href ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
